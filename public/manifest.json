{
    "manifest_version": 3,
    "name": "DivNotes",
    "description": "Select any element on a webpage and create rich notes against it. Your web annotations, everywhere.",
    "version": "1.0.0",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "src/popup/index.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png"
        },
        "default_title": "DivNotes"
    },
    "side_panel": {
        "default_path": "src/sidepanel/index.html"
    },
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "tabs",
        "storage",
        "sidePanel",
        "contextMenus"
    ],
    "commands": {
        "toggle-notes": {
            "suggested_key": {
                "default": "Ctrl+Shift+N",
                "mac": "Command+Shift+N"
            },
            "description": "Toggle all notes on current page"
        },
        "activate-inspector": {
            "suggested_key": {
                "default": "Ctrl+Shift+S",
                "mac": "Command+Shift+S"
            },
            "description": "Activate element selector"
        },
        "presentation-mode": {
            "suggested_key": {
                "default": "Ctrl+Shift+P",
                "mac": "Command+Shift+P"
            },
            "description": "Toggle Screen Share Mode"
        }
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "content/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}